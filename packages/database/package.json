{
  "name": "@udd/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/migrate.js",
    "dev": "tsc --watch",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@udd/config": "workspace:*",
    "@udd/contracts": "workspace:*",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "*",
    "vitest": "^2.0.0"
  }
}
